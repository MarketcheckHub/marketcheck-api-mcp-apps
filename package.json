{
  "name": "marketcheck-mcp-apps",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/shared",
    "packages/gallery",
    "packages/apps/*",
    "packages/chat/shared",
    "packages/chat/vercel-ai-chat",
    "packages/chat/copilotkit-chat",
    "packages/chat/assistant-ui-chat",
    "packages/chat/langchain-agent-chat"
  ],
  "scripts": {
    "build:shared": "cd packages/shared && npm run build",
    "build:apps": "node scripts/build-apps.mjs",
    "build:gallery": "cd packages/gallery && npx vite build",
    "build:server": "cd packages/server && npm run build",
    "build": "npm run build:shared && npm run build:apps && npm run build:gallery && node scripts/prepare-vercel.mjs",
    "build:full": "npm run build && npm run build:server",
    "serve": "npm run serve --workspace=@mcp-apps/server",
    "dev": "npm run build && npm run serve"
  },
  "devDependencies": {
    "puppeteer": "^24.40.0"
  }
}
